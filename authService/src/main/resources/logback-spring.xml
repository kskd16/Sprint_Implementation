<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback Configuration for SmartSure AuthService
    
    This configuration provides structured JSON logging for better log aggregation
    and analysis in distributed systems. It includes:
    - Console logging with colored output for development
    - File logging with JSON format for production
    - Distributed tracing integration
    - Different log levels for different packages
    - Log rotation and archival policies
    
    Author: SmartSure Development Team
    Version: 1.0
    Since: 2024-03-25
-->
<configuration>

	<!-- Define properties for log configuration -->
	<property name="LOG_PATH" value="./logs" />
	<property name="SERVICE_NAME" value="authService" />

	<!-- Console Appender for Development -->
	<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>
				%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level
				[%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n
</pattern>
		</encoder>
	</appender>

	<!-- File Appender with JSON Format for Production -->
	<appender name="FILE"
		class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${LOG_PATH}/${SERVICE_NAME}.log</file>
		<encoder
			class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
			<providers>
				<timestamp />
				<version />
				<logLevel />
				<message />
				<mdc />
				<arguments />
				<stackTrace />
				<pattern>
					<pattern>
						{
						"service": "${SERVICE_NAME}",
						"traceId": "%X{traceId:-}",
						"spanId": "%X{spanId:-}",
						"thread": "%thread",
						"logger": "%logger"
						}
					</pattern>
				</pattern>
			</providers>
		</encoder>

		<!-- Rolling Policy -->
		<rollingPolicy
			class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
			<fileNamePattern>
				${LOG_PATH}/${SERVICE_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
			<maxFileSize>100MB</maxFileSize>
			<maxHistory>30</maxHistory>
			<totalSizeCap>3GB</totalSizeCap>
		</rollingPolicy>
	</appender>

	<!-- Async Appender for Better Performance -->
	<appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
		<appender-ref ref="FILE" />
		<queueSize>1024</queueSize>
		<discardingThreshold>0</discardingThreshold>
		<includeCallerData>true</includeCallerData>
	</appender>

	<!-- Logger Configurations -->

	<!-- Application Loggers -->
	<logger name="com.smartSure.authService" level="INFO" additivity="false">
		<appender-ref ref="CONSOLE" />
		<appender-ref ref="ASYNC_FILE" />
	</logger>

	<!-- Security Loggers -->
	<logger name="org.springframework.security" level="DEBUG" additivity="false">
		<appender-ref ref="CONSOLE" />
		<appender-ref ref="ASYNC_FILE" />
	</logger>

	<!-- Cache Loggers -->
	<logger name="org.springframework.cache" level="DEBUG" additivity="false">
		<appender-ref ref="CONSOLE" />
		<appender-ref ref="ASYNC_FILE" />
	</logger>

	<!-- Database Loggers -->
	<logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
		<appender-ref ref="CONSOLE" />
		<appender-ref ref="ASYNC_FILE" />
	</logger>

	<!-- Tracing Loggers -->
	<logger name="brave" level="INFO" additivity="false">
		<appender-ref ref="CONSOLE" />
		<appender-ref ref="ASYNC_FILE" />
	</logger>

	<!-- Root Logger -->
	<root level="INFO">
		<appender-ref ref="CONSOLE" />
		<appender-ref ref="ASYNC_FILE" />
	</root>

</configuration>