              "raw": "{{CLAIM_BASE_URL}}/api/claims",
              "host": [
                "{{CLAIM_BASE_URL}}"
              ],
              "path": [
                "api",
                "claims"
              ]
            },
            "description": "📝 Create a new insurance claim (DRAFT status)\n\n**✅ TOKEN:** {{CUSTOMER_TOKEN}}\n\n**SAVES:** {{CLAIM_ID}}\n\n**RESPONSE:**\n```json\n{\n  \"id\": 1,\n  \"customerId\": 1,\n  \"policyId\": 1,\n  \"status\": \"DRAFT\",\n  \"description\": \"...\",\n  \"createdAt\": \"2026-03-30T10:00:00\"\n}\n```"
          }
